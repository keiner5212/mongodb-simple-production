# Copy to .env on the EC2 host: cp .env.example .env
# Never commit .env to version control.

COMPOSE_PROJECT_NAME=mongodb-prod

# MongoDB
MONGO_VERSION=7.0
MONGO_PORT=27017
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

# Host bind-mount paths (Debian EC2)
MONGO_DATA_DIR=/var/lib/mongodb/data
MONGO_CONFIG_DIR=/var/lib/mongodb/config
# Container RAM cap; WiredTiger cache = 50% (set automatically in scripts/mongod-entrypoint.sh)
MONGO_MEMORY_LIMIT=6g

# Automatic backups (mongo-backup service)
# Hours between each mongodump run
BACKUP_INTERVAL_HOURS=24
# Keep at most N backup directories (oldest removed first)
BACKUP_MAX_COUNT=14
BACKUP_HOST_DIR=/var/backups/mongodb
