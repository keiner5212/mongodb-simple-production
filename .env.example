# On the server: cp .env.example .env && nano .env
# Do not commit .env

COMPOSE_PROJECT_NAME=mongodb-prod

MONGO_PORT=27017
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

MONGO_DATA_DIR=/var/lib/mongodb/data
MONGO_CONFIG_DIR=/var/lib/mongodb/config
MONGO_MEMORY_LIMIT=3g

# After running scripts/setup-letsencrypt-tls.sh (see INSTALACION.md)
MONGO_TLS_ENABLED=false
MONGO_TLS_DIR=/var/lib/mongodb/tls
MONGO_TLS_MODE=requireTLS

BACKUP_INTERVAL_HOURS=24
BACKUP_MAX_COUNT=14
BACKUP_HOST_DIR=/var/backups/mongodb
